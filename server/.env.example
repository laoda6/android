# 复制本文件为 .env 并填入真实值（.env 已被 .gitignore 忽略，不会提交）

# 服务端口
PORT=3001
# JWT 签名密钥（任意一段随机字符串）
JWT_SECRET=change_this_to_a_random_secret

# ===== 大模型配置（主用 + 备用，均为 OpenAI 兼容协议） =====
# 程序优先调用"主用"，当主用超时或报错时自动切换到"备用"。

# 主用厂商
LLM_PRIMARY_NAME=火山方舟
LLM_PRIMARY_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
LLM_PRIMARY_API_KEY=
LLM_PRIMARY_MODEL=deepseek-v4-flash

# 备用厂商
LLM_FALLBACK_NAME=百炼
LLM_FALLBACK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=qwen-turbo

# 单次请求超时（毫秒）
LLM_TIMEOUT_MS=40000
